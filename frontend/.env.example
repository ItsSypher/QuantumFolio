# Copy to .env.local for local overrides (never commit .env.local)

# Backend base URL for HTTP API calls
# Dev default: http://localhost:8000 (proxy handles it, so not needed locally)
# Prod (Vercel): set to your deployed backend URL, e.g. https://quantumfolio-api.koyeb.app
VITE_API_URL=

# Backend base URL for WebSocket connections
# Dev default: ws://localhost:8000 (proxy handles it, so not needed locally)
# Prod (Vercel): set to wss://quantumfolio-api.koyeb.app
VITE_WS_URL=
